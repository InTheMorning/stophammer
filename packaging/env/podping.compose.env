# Docker Compose env for the bundled `podping` service.
# `/data` is the persistent podping volume inside the container.
# These values match the current `gossip-listener` environment contract from
# https://github.com/InTheMorning/podping.alpha .

IROH_NODE_KEY_FILE=/data/gossip_listener_node.key
KNOWN_PEERS_FILE=/data/gossip_listener_known_peers.txt
TRUSTED_PUBLISHERS_FILE=/data/trusted_publishers.txt
DHT_INITIAL_SECRET=podping_gossip_default_secret

ARCHIVE_ENABLED=true
ARCHIVE_PATH=/data/archive.db

SSE_ENABLED=true
SSE_BIND_ADDR=0.0.0.0:8089
SSE_BUFFER_SIZE=1000

# Optional protocol tuning
# BOOTSTRAP_PEER_IDS=
# NODE_FRIENDLY_NAME=
# PEER_ANNOUNCE_INTERVAL=300
# PEER_ENDORSE_INTERVAL=45
