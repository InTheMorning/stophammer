# stophammer-gossip.service environment

# Required
# CRAWL_TOKEN=change-me
# INGEST_URL=http://localhost:8008/ingest/feed

# Runtime state
# GOSSIP_STATE_DB=/var/lib/stophammer-crawler/gossip_state.db
# FEED_SKIP_DB=/var/lib/stophammer-crawler/feed_skip.db

# Live SSE
# GOSSIP_SSE_URL=http://localhost:8089/events

# Optional archive-backed replay
# GOSSIP_ARCHIVE_DB=/path/to/archive.db
# GOSSIP_SINCE_HOURS=

# Crawl behavior
# CONCURRENCY=3
# GOSSIP_SKIP_KNOWN_NON_MUSIC=1
# GOSSIP_SKIP_TTL_DAYS=
# GOSSIP_QUIET=0
# RUST_LOG=info

# Audit NDJSON output (feed_audit format, shared with import mode)
# GOSSIP_AUDIT_OUTPUT=stored-feeds.ndjson
# GOSSIP_AUDIT_REPLACE=0

# Note:
# - If GOSSIP_ARCHIVE_DB is set, the service user must have read access to that file.
# - With the packaged systemd unit, that usually means installing podping.alpha /
#   gossip-listener on the same host, enabling archive writes there, and adding
#   the `stophammer-crawler` user to the `podping` group.
