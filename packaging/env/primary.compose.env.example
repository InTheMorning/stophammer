# Docker Compose env for the `primary` service.
# These paths are container-internal and assume the service volume is mounted at `/data`.
# Do not copy the host/systemd `*.env.example` values here unchanged.

# Startup mode
NODE_MODE=primary

# Required
# CRAWL_TOKEN=change-me
# SYNC_TOKEN=change-me

# Common runtime
DB_PATH=/data/stophammer.db
KEY_PATH=/data/signing.key
BIND=0.0.0.0:8008
RUST_LOG=stophammer=info

# Optional auth
# ADMIN_TOKEN=

# Rate limiting / proxy / CORS
# RATE_LIMIT_RPS=50
# RATE_LIMIT_BURST=100
# TRUST_PROXY=false
# CORS_ALLOW_ORIGIN=*

# Background maintenance
# PROOF_PRUNE_INTERVAL_SECS=300

# Ingest verifier configuration
# VERIFIER_CHAIN=crawl_token,content_hash,feed_blocklist,medium_music,feed_guid,v4v_payment,enclosure_type
# BLOCKED_FEED_GUIDS=
# BLOCKED_FEED_URLS=

# Optional ACME / TLS
# For reverse-proxy TLS termination in Docker, usually leave TLS_* unset
# and set TRUST_PROXY=true instead.
# TLS_DOMAIN=
# TLS_ACME_EMAIL=
# TLS_CERT_PATH=./tls/cert.pem
# TLS_KEY_PATH=./tls/key.pem
# TLS_ACME_STAGING=false
# TLS_ACME_ACCOUNT_PATH=./tls/acme-account.json
# TLS_ACME_DIRECTORY_URL=
