# stophammer-primary.service environment

# Required
# CRAWL_TOKEN=change-me
# SYNC_TOKEN=change-me

# Common runtime
# DB_PATH=/var/lib/stophammer/stophammer.db
# KEY_PATH=/var/lib/stophammer/signing.key
# BIND=0.0.0.0:8008
# RUST_LOG=stophammer=info

# Optional
# ADMIN_TOKEN=
# VERIFIER_CHAIN=crawl_token,content_hash,feed_blocklist,medium_music,feed_guid,v4v_payment,enclosure_type
# TLS_MODE=off
# TLS_CERT_PATH=
# TLS_KEY_PATH=
# TLS_ACME_DOMAIN=
# TLS_ACME_EMAIL=
