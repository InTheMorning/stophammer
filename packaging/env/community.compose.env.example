# Docker Compose env for a `community` service.
# These paths are container-internal and assume the service volume is mounted at `/data`.
# The example URLs below assume the primary and this community node share the same
# Docker network and are reachable by Compose service name.

NODE_MODE=community
PRIMARY_URL=http://primary:8008
NODE_ADDRESS=http://community:8008
SYNC_TOKEN=change-me

DB_PATH=/data/stophammer.db
KEY_PATH=/data/signing.key
BIND=0.0.0.0:8008
ALLOW_INSECURE_PUBKEY_DISCOVERY=true
RUST_LOG=stophammer=info

# Optional auth
# ADMIN_TOKEN=

# Community sync hardening / tuning
# PRIMARY_PUBKEY=
# TRACKER_URL=https://stophammer-tracker.workers.dev
# POLL_INTERVAL_SECS=300
# PUSH_TIMEOUT_SECS=90

# Rate limiting / proxy / CORS
# RATE_LIMIT_RPS=50
# RATE_LIMIT_BURST=100
# TRUST_PROXY=false
# CORS_ALLOW_ORIGIN=*

# Background maintenance
# PROOF_PRUNE_INTERVAL_SECS=300

# Optional ACME / TLS
# TLS_DOMAIN=
# TLS_ACME_EMAIL=
# TLS_CERT_PATH=./tls/cert.pem
# TLS_KEY_PATH=./tls/key.pem
# TLS_ACME_STAGING=false
# TLS_ACME_ACCOUNT_PATH=./tls/acme-account.json
# TLS_ACME_DIRECTORY_URL=
