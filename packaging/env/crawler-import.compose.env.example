# Docker Compose env for the one-shot `import` service.
# `/data` is the crawler state volume inside the container.
# These values are consumed by the compose command wrapper, which turns them
# into `stophammer-crawler import ...` flags.

CRAWL_TOKEN=change-me
INGEST_URL=http://primary:8008/ingest/feed

IMPORT_STATE_DB=/data/import_state.db
FEED_SKIP_DB=/data/feed_skip.db
PODCASTINDEX_DB=/data/podcastindex_feeds.db
PODCASTINDEX_DB_URL=https://public.podcastindex.org/podcastindex_feeds.db.tgz

CONCURRENCY=5
IMPORT_BATCH=100

# Optional import behavior
 IMPORT_CURSOR=4630863
 IMPORT_SKIP_KNOWN_NON_MUSIC=1
# FORCE_REINGEST=0
# IMPORT_SKIP_KNOWN_SUCCESS=0
# IMPORT_REFRESH_DB=0
# IMPORT_AUDIT_OUTPUT=stored-feeds.ndjson
# IMPORT_AUDIT_REPLACE=0
# IMPORT_WAVLAKE_ONLY=0
# IMPORT_DRY_RUN=0

# Optional image override in the project environment or top-level `.env`:
# STOPHAMMER_CRAWLER_IMAGE=stophammer-crawler
