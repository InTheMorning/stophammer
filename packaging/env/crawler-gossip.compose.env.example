# Docker Compose env for the `gossip` service.
# `/data` is the crawler state volume inside the container.
# `/podping` is the read-only shared podping-listener volume configured by `docker-compose.yml`.
# These values are consumed by the compose command wrapper, which turns them
# into `stophammer-crawler gossip ...` flags.

CRAWL_TOKEN=change-me
INGEST_URL=http://primary:8008/ingest/feed
GOSSIP_STATE_DB=/data/gossip_state.db
FEED_SKIP_DB=/data/feed_skip.db
GOSSIP_ARCHIVE_DB=/podping/archive.db
GOSSIP_SSE_URL=http://podping-listener:8089/events
CONCURRENCY=3
GOSSIP_SKIP_KNOWN_NON_MUSIC=1
RUST_LOG=info

# Optional replay / skip tuning
# FORCE_REINGEST=0
# GOSSIP_SINCE_HOURS=
# GOSSIP_SKIP_TTL_DAYS=
# GOSSIP_QUIET=0

# Cached-feed NDJSON output (shared with import mode)
# GOSSIP_AUDIT_OUTPUT=/data/stored-feeds.ndjson
# GOSSIP_AUDIT_REPLACE=0
