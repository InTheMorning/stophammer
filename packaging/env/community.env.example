# stophammer-community.service environment

# Required
# PRIMARY_URL=https://primary.example
# NODE_ADDRESS=https://community.example
# SYNC_TOKEN=change-me

# Common runtime
# NODE_MODE=community
# DB_PATH=/var/lib/stophammer/stophammer.db
# KEY_PATH=/var/lib/stophammer/signing.key
# BIND=0.0.0.0:8008
# RUST_LOG=stophammer=info

# Optional
# TRACKER_URL=https://primary.example
# PRIMARY_PUBKEY=
# ALLOW_INSECURE_PUBKEY_DISCOVERY=false
# POLL_INTERVAL_SECS=300
# PUSH_TIMEOUT_SECS=90
