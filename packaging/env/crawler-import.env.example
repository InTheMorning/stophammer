# Example environment for one-shot import runs

# Required
# CRAWL_TOKEN=change-me
# INGEST_URL=http://127.0.0.1:8008/ingest/feed

# State
# IMPORT_STATE_DB=/var/lib/stophammer-crawler/import_state.db
# FEED_SKIP_DB=/var/lib/stophammer-crawler/feed_skip.db
# PODCASTINDEX_DB=/var/lib/stophammer-crawler/podcastindex_feeds.db

# Import behavior
# CONCURRENCY=5
# IMPORT_BATCH=100
# IMPORT_CURSOR=
# IMPORT_SKIP_KNOWN_NON_MUSIC=true
# IMPORT_SKIP_KNOWN_SUCCESS=false
