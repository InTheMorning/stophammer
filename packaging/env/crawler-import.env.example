# Example environment for one-shot import runs

# Required
# CRAWL_TOKEN=change-me
# INGEST_URL=http://localhost:8008/ingest/feed

# State
# IMPORT_STATE_DB=/var/lib/stophammer-crawler/import_state.db
# FEED_SKIP_DB=/var/lib/stophammer-crawler/feed_skip.db
# PODCASTINDEX_DB=/var/lib/stophammer-crawler/podcastindex_feeds.db
# PODCASTINDEX_DB_URL=https://public.podcastindex.org/podcastindex_feeds.db.tgz

# Import behavior
# CONCURRENCY=5
# IMPORT_BATCH=100
# IMPORT_CURSOR=
# IMPORT_SKIP_KNOWN_NON_MUSIC=0
# IMPORT_SKIP_KNOWN_SUCCESS=0
# IMPORT_REFRESH_DB=0
# IMPORT_AUDIT_OUTPUT=
# IMPORT_AUDIT_REPLACE=0
# IMPORT_WAVLAKE_ONLY=0
# IMPORT_DRY_RUN=0

# Optional resolver coordination
# RESOLVER_DB_PATH=
# RESOLVERCTL_BIN=stophammer-resolverctl
