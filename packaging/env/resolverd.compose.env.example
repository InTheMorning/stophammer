# Docker Compose env for the `resolverd` service.
# These paths are container-internal and assume the shared primary volume is mounted at `/data`.

DB_PATH=/data/stophammer.db
KEY_PATH=/data/signing.key
RESOLVER_INTERVAL_SECS=30
RESOLVER_BATCH_SIZE=25
RESOLVER_EMIT_RESOLVED_STATE_EVENTS=true
RUST_LOG=stophammer=info

# Optional overrides
# NODE_MODE=primary
# RESOLVER_WORKER_ID=stophammer-resolverd-<pid>
