# Docker Compose env for the one-shot `import-wavlake` service.
# Imports only Wavlake feeds with single-flight fetches and rate-limit throttling.
# Shares state/skip/podcastindex DBs with the `import` service safely —
# cursor progress is tracked under a separate key (last_processed_id:wavlake_only).

CRAWL_TOKEN=change-me
INGEST_URL=http://primary:8008/ingest/feed

IMPORT_STATE_DB=/data/import_state.db
FEED_SKIP_DB=/data/feed_skip.db
PODCASTINDEX_DB=/data/podcastindex_feeds.db
PODCASTINDEX_DB_URL=https://public.podcastindex.org/podcastindex_feeds.db.tgz

CONCURRENCY=1
IMPORT_BATCH=100
IMPORT_WAVLAKE_ONLY=1

# Optional import behavior
# IMPORT_CURSOR=
# IMPORT_SKIP_KNOWN_NON_MUSIC=0
# IMPORT_SKIP_KNOWN_SUCCESS=0
# IMPORT_REFRESH_DB=0
# IMPORT_AUDIT_OUTPUT=
# IMPORT_AUDIT_REPLACE=0
# IMPORT_DRY_RUN=0
