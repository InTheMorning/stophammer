# stophammer-resolverd.service environment

# Primary-only guard
# NODE_MODE=primary

# Shared primary database
# DB_PATH=/var/lib/stophammer/stophammer.db
# KEY_PATH=/var/lib/stophammer/signing.key
# RUST_LOG=stophammer=info

# Resolver tuning
# RESOLVER_INTERVAL_SECS=30
# RESOLVER_BATCH_SIZE=25
# RESOLVER_WORKER_ID=stophammer-resolverd-<pid>
# RESOLVER_EMIT_RESOLVED_STATE_EVENTS=true
