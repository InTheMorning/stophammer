# Docker Compose env for a one-shot `crawl` service.
# `/data` is the crawler state volume inside the container.
# The ingest target below assumes the crawler and primary share the same
# Docker network and the primary is reachable as `http://primary:8008`.

CRAWL_TOKEN=change-me
INGEST_URL=http://primary:8008/ingest/feed

# Crawl input
# FEED_URLS=

# Crawl behavior
CONCURRENCY=5
HOST_DELAY_MS=1500
FAILED_FEEDS_OUTPUT=/data/failed_feeds.txt
