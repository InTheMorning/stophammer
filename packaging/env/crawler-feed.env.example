# Example environment for one-shot feed runs (stophammer-crawler feed)

# Required
# CRAWL_TOKEN=change-me

# Ingest target
# INGEST_URL=http://localhost:8008/ingest/feed

# Crawl input
# FEED_URLS=

# Crawl behavior
# Force re-ingestion even if feed content has not changed
# FORCE_REINGEST=0

# CONCURRENCY=5
# HOST_DELAY_MS=1500
# FAILED_FEEDS_OUTPUT=./failed_feeds.txt
